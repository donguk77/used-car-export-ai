    <script type="996446d2f4c5b246258e7fe4-text/javascript">
      // Fungsi untuk mendapatkan nama hari
      function getDayName(dayIndex) {
          const days = ["Min", "Sen", "Sel", "Rab", "Kam", "Jum", "Sab"];
          return days[dayIndex] || "";
      }
      
      // Dapatkan elemen tanggal
      const dateElement = document.querySelector('[data-section="date"]');
      
      if (dateElement) {
          const today = new Date();
          const dayName = getDayName(today.getDay());
          const dd = String(today.getDate()).padStart(2, "0");
          const mm = String(today.getMonth() + 1).padStart(2, "0"); // bulan dimulai dari 0
          const yy = String(today.getFullYear()).slice(-2); // dua digit tahun
          dateElement.textContent = `${dayName}, ${dd}/${mm}/${yy} - Powered by SEOBIRAHI.`;
      }
   </script>
    <style>
        .custom-banner {
            position: relative;
            width: 100%;
            aspect-ratio: 1800 / 574;
            overflow: hidden;
        }
        .custom-banner .slides {
            display: flex;
            transition: transform 0.5s ease-in-out;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }
        .custom-banner .slide {
            flex: 0 0 100%;
            height: 100%;
        }
        .custom-banner .slide img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }
    </style>
