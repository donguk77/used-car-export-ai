# 백엔드 환경변수 — 복사 후 채워서 사용:
#     cp .env.example .env
# 이 파일은 git 추적, 실제 .env 는 .gitignore.

# ── 앱 ────────────────────────────────────────────────────
APP_ENV=development          # development / staging / production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── DB (Neon Postgres 권장 — managed, free tier) ─────────
# 로컬: postgresql+psycopg://postgres:postgres@localhost:5432/used_car_export
# Neon: postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/used_car_export
DATABASE_ECHO=false

# ── LLM provider ─────────────────────────────────────────
# stub: API 키 없이 placeholder 응답 (오프라인 데모용)
# gemini: 무료, 60 req/min — 추천 (https://aistudio.google.com/app/apikey)
# anthropic: 유료, 품질 ↑ — 한국어/Arabic 격식 검증 완료
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 외부 API endpoint (변경 불필요, 기본값으로 작동) ────────
NHTSA_VPIC_BASE=https://vpic.nhtsa.dot.gov/api
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
YESTRADE_BASE=https://www.yestrade.go.kr

# ── 통관 룰 yaml 시드 경로 (프로젝트 루트 기준) ────────────
RULES_DIR=configs/rules
