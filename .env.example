# ──────────────────────────────────────────
# 중고차 수출 AI 에이전트 — 환경 변수 템플릿
# 실제 값이 든 .env 는 절대 git 에 올리지 말 것
# ──────────────────────────────────────────

# LLM Provider — anthropic | gemini | stub
# 키 없을 땐 stub 으로 둬도 demo_mail_writer.py 실행 가능
LLM_PROVIDER=stub

# Anthropic API (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini API (https://aistudio.google.com 에서 발급, 무료티어)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/used_car_export
DATABASE_ECHO=false

# 외부 API
NHTSA_VPIC_BASE=https://vpic.nhtsa.dot.gov/api
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
YESTRADE_BASE=https://www.yestrade.go.kr

# 앱 설정
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# 룰엔진 시드 경로 (configs/rules/*.yaml)
RULES_DIR=configs/rules
